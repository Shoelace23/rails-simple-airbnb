<%= simple_form_for(@flat) do |f| %>
  <div class="bg-white p-5 rounded-4 shadow-sm border">
    <%= f.input :name, placeholder: "Light & Spacious Garden Flat London", input_html: { class: "mb-3" } %>
    <%= f.input :address, placeholder: "10 Clifton Gardens London W9 1DT", input_html: { class: "mb-3" } %>
    
    <%= f.input :description, placeholder: "A lovely summer feel for this spacious garden flat...", input_html: { rows: 5, class: "mb-3" } %>
    
    <div class="row mb-3">
      <div class="col-md-6">
        <%= f.input :price_per_night, label: "Price per night (€)", wrapper_html: { class: "mb-0" } %>
      </div>
      <div class="col-md-6">
        <%= f.input :number_of_guests, wrapper_html: { class: "mb-0" } %>
      </div>
    </div>
    
    <%= f.input :picture_url, label: "Picture URL", placeholder: "https://images.unsplash.com/photo-...", hint: "Provide a valid image URL to display on the flat's card.", input_html: { class: "mb-4" } %>
    
    <div class="d-flex justify-content-between align-items-center mt-4 pt-3 border-top">
      <%= link_to flats_path, class: "btn btn-light rounded-pill px-4" do %>
        <i class="fa-solid fa-arrow-left me-2"></i>Cancel
      <% end %>
      <%= f.submit class: "btn btn-primary rounded-pill px-5 fw-bold" %>
    </div>
  </div>
<% end %>
